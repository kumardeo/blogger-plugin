{
  "name": "blogger-plugin",
  "version": "0.0.9",
  "description": "A plugin which allows you to use frontend frameworks in a blogger template.",
  "keywords": [
    "blogger"
  ],
  "license": "MIT",
  "author": {
    "name": "Deo Kumar",
    "email": "deo@fineshopdesign.com",
    "url": "https://github.com/kumardeo"
  },
  "homepage": "https://github.com/bloggerkit/blogger-plugin/tree/main/packages/blogger-plugin#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bloggerkit/blogger-plugin",
    "directory": "packages/blogger-plugin"
  },
  "bugs": {
    "url": "https://github.com/bloggerkit/blogger-plugin/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "lint": "biome lint ./src",
    "check": "biome check ./src",
    "check:types": "tsc --noEmit",
    "build": "NODE_ENV=production tsdown",
    "dev": "NODE_ENV=development tsdown --watch"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    }
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "tailwindcss-iso": "^1.0.6"
  },
  "devDependencies": {
    "@types/node": "catalog:default",
    "tsdown": "catalog:default",
    "vite": "^7.0.0"
  }
}
